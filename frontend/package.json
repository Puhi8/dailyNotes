{
  "name": "package",
  "private": true,
  "version": "2.1.1",
  "type": "module",
  "homepage": "https://Puhi8.github.io/dailyNotes",
  "scripts": {
    "dev": "vite --port 9998",
    "build": "tsc -b && vite build",
    "deploy": "VITE_ROUTER_MODE=hash VITE_PUBLIC_BASE_PATH=/dailyNotes/ npm run build && gh-pages -d dist -r https://github.com/Puhi8/dailyNotes.git",
    "lint": "eslint .",
    "preview": "vite preview",
    "version:set": "bash ../set-version.sh",
    "android:icons": "bash ./scripts/sync-android-icon.sh",
    "android:sync": "bash ./scripts/prepare-android-project.sh",
    "android:open": "npm run android:sync && cap open android",
    "android:build": "bash ./scripts/build-android-apk.sh",
    "electron:add": "cap add @capacitor-community/electron",
    "electron:sync": "cap sync electron",
    "electron:open": "cap open electron",
    "windows:build": "cap sync electron && npm --prefix electron run build"
  },
  "dependencies": {
    "@capacitor/android": "8.3.0",
    "@capacitor/app": "8.1.0",
    "@capacitor/cli": "8.3.0",
    "@capacitor/core": "8.3.0",
    "@capgo/capacitor-native-biometric": "8.4.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-dom": "7.14.0",
    "recharts": "3.8.1"
  },
  "devDependencies": {
    "@capacitor-community/electron": "5.0.1",
    "@eslint/js": "9.39.4",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.26",
    "globals": "16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.58.0",
    "vite": "7.3.1",
    "gh-pages": "6.3.0"
  }
}
